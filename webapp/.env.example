# Tableau Configuration
# Use the URL from the "Share" button on your published view, in the form:
#   https://public.tableau.com/views/YourWorkbook/YourView
# (the /app/profile/.../viz/... URL from your browser address bar usually
# also works in an iframe, but the /views/ form from Share is the one
# Tableau explicitly designs for embedding -- if the iframe shows blank,
# switch to that form.)
TABLEAU_EMBED_URL=https://public.tableau.com/views/India_Electricity_Consumption_Story/Story1
